{
  "name": "gestion-comercio",
  "version": "1.3.0",
  "description": "Nexo Commerce — Sistema de gestión para comercios",
  "author": {
    "name": "ShangoTech",
    "email": "soporteshangotech@gmail.com"
  },
  "main": "out/main/index.js",
  "scripts": {
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "electron-vite build && electron-builder",
    "dist:win": "electron-vite build && electron-builder --win",
    "dist:store": "electron-vite build && electron-builder --win --config.win.target=appx",
    "dist:linux": "electron-vite build && electron-builder --linux",
    "dev:pwa": "vite --config vite.pwa.config.js",
    "build:pwa": "vite build --config vite.pwa.config.js",
    "preview:pwa": "vite preview --config vite.pwa.config.js",
    "build:all": "npm run build && npm run build:pwa"
  },
  "dependencies": {
    "@ant-design/icons": "^5.5.0",
    "@electron-toolkit/utils": "^4.0.0",
    "antd": "^5.22.0",
    "better-sqlite3": "^11.5.0",
    "dayjs": "^1.11.13",
    "electron-updater": "^6.8.3",
    "i18next": "^26.0.3",
    "node-machine-id": "^1.1.12",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.2",
    "react-router-dom": "^6.28.0",
    "recharts": "^2.13.3",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "vite": "^5.4.0",
    "vite-plugin-pwa": "^1.2.0"
  },
  "build": {
    "appId": "com.comercio.gestion",
    "productName": "Nexo Commerce",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": "resources"
      }
    ],
    "win": {
      "target": [
        "nsis",
        "appx"
      ],
      "icon": "resources/icon.ico"
    },
    "appx": {
      "publisher": "CN=3CE17C7B-F3A6-4AD6-A06F-2AED692EA622",
      "publisherDisplayName": "ShangoTech",
      "identityName": "ShangoTech.NexoCommerce",
      "applicationId": "NexoCommerce",
      "displayName": "Nexo Commerce"
    },
    "linux": {
      "target": "AppImage",
      "icon": "resources/icon.png"
    },
    "publish": {
      "provider": "github",
      "owner": "juanjocurutchet",
      "repo": "gestion-comercio-releases",
      "releaseType": "release"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "resources/icon.ico",
      "uninstallerIcon": "resources/icon.ico",
      "installerHeaderIcon": "resources/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Nexo Commerce"
    }
  }
}
